# JARVIS Backend
JARVIS_BACKEND_HOST=0.0.0.0
JARVIS_BACKEND_PORT=8181

# Secrets: echte Werte nur in backend/.env speichern, nie committen.
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
JARVIS_AGENT_TOKEN=CHANGE_ME_AGENT_TOKEN
JARVIS_BOT_BRIDGE_TOKEN=CHANGE_ME_BOT_BRIDGE_TOKEN
JARVIS_DASHBOARD_TOKEN=CHANGE_ME_DASHBOARD_TOKEN

# OpenAI Realtime Voice
JARVIS_REALTIME_MODEL=gpt-4o-realtime-preview
JARVIS_REALTIME_VOICE=verse
JARVIS_REALTIME_INSTRUCTIONS=Du bist JARVIS, ein deutscher persönlicher Windows-Desktop-Assistent. Antworte kurz, präzise und führe Aktionen nur über freigegebene Tools aus.
JARVIS_OPENAI_CHAT_MODEL=gpt-4.1-mini

# Discord Policy
JARVIS_ALLOWED_DISCORD_USER_IDS=CHANGE_ME_DISCORD_USER_ID
JARVIS_ALLOWED_DISCORD_ROLE_IDS=

# Command Safety
JARVIS_COMMAND_RATE_LIMIT_WINDOW_SECONDS=60
JARVIS_COMMAND_RATE_LIMIT_MAX=3
JARVIS_COMMAND_CLAIM_TIMEOUT_SECONDS=120

# News
JARVIS_NEWS_CACHE_TTL_SECONDS=900
JARVIS_NEWS_MAX_ITEMS=12
